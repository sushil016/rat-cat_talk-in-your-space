// Prisma Schema for Rat-Cat (NextAuth compatible)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  isNewUser     Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  rooms        Room[]
  participants Participant[]
  messages     Message[]

  // Friends
  sentRequests     Friendship[] @relation("FriendRequestSender")
  receivedRequests Friendship[] @relation("FriendRequestReceiver")
}

model Friendship {
  id        String   @id @default(cuid())
  status    String   @default("pending") // "pending" | "accepted" | "rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderId String
  sender   User   @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model Room {
  id              String   @id @default(cuid())
  code            String   @unique
  slug            String   @unique
  name            String
  description     String?
  thumbnailUrl    String?
  isPublic        Boolean  @default(false)
  password        String?
  maxParticipants Int      @default(10)
  roomType        String   @default("chill") // "coding" | "chill"
  resourceUrl     String?
  theme           String   @default("neutral") // "rat_den" | "cat_lounge" | "neutral"
  status          String   @default("waiting") // "waiting" | "live" | "ended"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hostId String
  host   User   @relation(fields: [hostId], references: [id], onDelete: Cascade)

  participants Participant[]
  messages     Message[]

  // Current media state
  mediaUrl     String?
  mediaType    String? // "youtube" | "upload" | "direct"
  mediaTitle   String?
  isPlaying    Boolean @default(false)
  currentTime  Float   @default(0)
  playbackRate Float   @default(1)

  @@index([code])
  @@index([slug])
  @@index([hostId])
}

model Participant {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  role       String  @default("participant") // "host" | "participant" | "guest"
  isMuted    Boolean @default(false)
  isDeafened Boolean @default(false)
  isReady    Boolean @default(false)

  // Guest mode fields
  guestName   String?
  guestAvatar String?

  @@unique([userId, roomId])
  @@index([roomId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text") // "text" | "reaction" | "system"
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
}
